<?xml version="1.0" encoding="UTF-8"?>
<job>
  <name>ETL Diario Ventas</name>
  <description>Job diario: SOAP -> staging -> upsert ventas_historicas -> predict.py -> limpiar staging</description>

  <!-- Parámetros -->
  <parameters>
    <parameter><name>WS_START_DATE</name><default_value>${WS_START_DATE}</default_value></parameter>
    <parameter><name>CHUNK_DAYS</name><default_value>${CHUNK_DAYS}</default_value></parameter>
    <parameter><name>PREDICT_PERIODS</name><default_value>${PREDICT_PERIODS}</default_value></parameter>
    <parameter><name>PREDICT_MODEL_SET</name><default_value>${PREDICT_MODEL_SET}</default_value></parameter>
    <parameter><name>PREDICT_VERSION</name><default_value>${PREDICT_VERSION}</default_value></parameter>
  </parameters>

  <!-- Conexión MySQL -->
  <connection>
    <name>MYSQL_EVALUTIA</name>
    <server>${MYSQL_HOST}</server>
    <type>MYSQL</type>
    <access>Native</access>
    <database>${MYSQL_DB}</database>
    <port>${MYSQL_PORT}</port>
    <username>${MYSQL_USER}</username>
    <password>${MYSQL_PASSWORD}</password>
    <using_unique_connections>N</using_unique_connections>
    <attributes>
      <attribute><code>EXTRA_OPTION_MYSQL.useSSL</code><attribute>false</attribute></attribute>
      <attribute><code>EXTRA_OPTION_MYSQL.allowPublicKeyRetrieval</code><attribute>true</attribute></attribute>
    </attributes>
  </connection>

  <entries>
    <!-- START -->
    <entry>
      <name>START</name>
      <type>SPECIAL</type>
      <start>Y</start>
      <repeat>N</repeat>
      <schedulerType>0</schedulerType>
      <xloc>64</xloc><yloc>64</yloc><draw>Y</draw>
    </entry>

    <!-- 0) Truncar staging al inicio -->
    <entry>
      <name>TRUNCATE STAGE (start)</name>
      <type>SQL</type>
      <connection>MYSQL_EVALUTIA</connection>
      <sql_script><![CDATA[TRUNCATE TABLE ventas_historicas_stage;]]></sql_script>
      <send_one_statement>Y</send_one_statement>
      <xloc>320</xloc><yloc>64</yloc><draw>Y</draw>
    </entry>

    <!-- 1) Obtener última fecha -->
    <entry>
      <name>GET LAST DATE</name>
      <type>TRANS</type>
      <filename>${Internal.Entry.Current.Directory}/tr_get_last_date.ktr</filename>
      <wait>Y</wait>
      <execute_each_row>N</execute_each_row>
      <parameters>
        <parameter><name>START_DATE_PARAM</name><value>${WS_START_DATE}</value></parameter>
      </parameters>
      <clear_result_rows>N</clear_result_rows>
      <xloc>560</xloc><yloc>64</yloc><draw>Y</draw>
    </entry>

    <!-- 2) Generar chunks -->
    <entry>
      <name>GEN CHUNKS</name>
      <type>TRANS</type>
      <filename>${Internal.Entry.Current.Directory}/tr_generate_chunks.ktr</filename>
      <wait>Y</wait>
      <execute_each_row>N</execute_each_row>
      <parameters>
        <parameter><name>LAST_DATE</name><value>${LAST_LOADED_DATE}</value></parameter>
        <parameter><name>CHUNK_DAYS</name><value>${CHUNK_DAYS}</value></parameter>
      </parameters>
      <clear_result_rows>N</clear_result_rows>
      <xloc>800</xloc><yloc>64</yloc><draw>Y</draw>
    </entry>

    <!-- 3) Ejecutar extracción por cada fila (chunk) -->
    <entry>
      <name>LOAD SALES CHUNK</name>
      <type>TRANS</type>
      <filename>${Internal.Entry.Current.Directory}/tr_extract_sales_chunk.ktr</filename>
      <wait>Y</wait>
      <execute_each_row>Y</execute_each_row>
      <parameters>
        <parameter><name>CHUNK_START</name><value>${CHUNK_START}</value></parameter>
        <parameter><name>CHUNK_END</name><value>${CHUNK_END}</value></parameter>
      </parameters>
      <clear_result_rows>N</clear_result_rows>
      <xloc>1040</xloc><yloc>64</yloc><draw>Y</draw>
    </entry>

    <!-- 4) Upsert staging -> ventas_historicas -->
    <entry>
      <name>MERGE STAGING -> VENTAS</name>
      <type>SQL</type>
      <connection>MYSQL_EVALUTIA</connection>
      <sql_script><![CDATA[
INSERT INTO ventas_historicas (fecha, sku, cantidad, ts_carga, fuente)
SELECT s.fecha, s.sku, s.cantidad, NOW(6), s.fuente
FROM ventas_historicas_stage s
ON DUPLICATE KEY UPDATE 
  cantidad = VALUES(cantidad),
  ts_carga = VALUES(ts_carga);
      ]]></sql_script>
      <send_one_statement>Y</send_one_statement>
      <xloc>1280</xloc><yloc>64</yloc><draw>Y</draw>
    </entry>

    <!-- 5) Ejecutar predict.py -->
    <entry>
      <name>RUN PREDICT.PY</name>
      <type>SHELL</type>
      <filename>/bin/sh</filename>
      <arguments>
        <argument>-lc</argument>
        <argument>python3 /app/services/python-worker/predict.py --input-source=mysql --periods=${PREDICT_PERIODS} --model-set=${PREDICT_MODEL_SET} --version=${PREDICT_VERSION}</argument>
      </arguments>
      <arg_from_previous>N</arg_from_previous>
      <exec_per_row>N</exec_per_row>
      <insertScript>N</insertScript>
      <set_logfile>N</set_logfile>
      <wait>Y</wait>
      <fail_when_not_success>Y</fail_when_not_success>
      <xloc>1520</xloc><yloc>64</yloc><draw>Y</draw>
    </entry>


    <!-- 6) Limpiar staging -->
    <entry>
      <name>TRUNCATE STAGE (end)</name>
      <type>SQL</type>
      <connection>MYSQL_EVALUTIA</connection>
      <sql_script><![CDATA[TRUNCATE TABLE ventas_historicas_stage;]]></sql_script>
      <send_one_statement>Y</send_one_statement>
      <xloc>1760</xloc><yloc>64</yloc><draw>Y</draw>
    </entry>

    <!-- SUCCESS -->
    <entry>
      <name>SUCCESS</name>
      <type>SPECIAL</type>
      <success>Y</success>
      <xloc>2000</xloc><yloc>64</yloc><draw>Y</draw>
    </entry>
  </entries>

  <hops>
    <hop><from>START</from><to>TRUNCATE STAGE (start)</to><enabled>Y</enabled><evaluation>Y</evaluation><unconditional>Y</unconditional></hop>
    <hop><from>TRUNCATE STAGE (start)</from><to>GET LAST DATE</to><enabled>Y</enabled><evaluation>Y</evaluation><unconditional>Y</unconditional></hop>
    <hop><from>GET LAST DATE</from><to>GEN CHUNKS</to><enabled>Y</enabled><evaluation>Y</evaluation><unconditional>Y</unconditional></hop>
    <hop><from>GEN CHUNKS</from><to>LOAD SALES CHUNK</to><enabled>Y</enabled><evaluation>Y</evaluation><unconditional>Y</unconditional></hop>
    <hop><from>LOAD SALES CHUNK</from><to>MERGE STAGING -> VENTAS</to><enabled>Y</enabled><evaluation>Y</evaluation><unconditional>Y</unconditional></hop>
    <hop><from>MERGE STAGING -> VENTAS</from><to>RUN PREDICT.PY</to><enabled>Y</enabled><evaluation>Y</evaluation><unconditional>Y</unconditional></hop>
    <hop><from>RUN PREDICT.PY</from><to>TRUNCATE STAGE (end)</to><enabled>Y</enabled><evaluation>Y</evaluation><unconditional>Y</unconditional></hop>
    <hop><from>TRUNCATE STAGE (end)</from><to>SUCCESS</to><enabled>Y</enabled><evaluation>Y</evaluation><unconditional>Y</unconditional></hop>
  </hops>

  <job_parameters>
    <pass_all_parameters>Y</pass_all_parameters>
  </job_parameters>
</job>
