<?xml version="1.0" encoding="UTF-8"?>
<job>
  <name>job_etl_diario</name>
  <description>Job diario: articulos, stockxml, ventas, merges y calculos</description>

  <parameters>
    <parameter><name>WS_URL</name><default_value>${WS_URL}</default_value></parameter>
    <parameter><name>DATE_FMT</name><default_value>dmy</default_value></parameter>
    <parameter><name>ID_EMPRESA</name><default_value>1</default_value></parameter>
    <parameter><name>S_DEPOSITOS</name><default_value>1,5</default_value></parameter>
    <!-- Vacios por default (Issue #42): run_extract_articulos.sh/run_extract_sales_chunk.sh
         consultan la tabla `grupos` via get_grupos.py cuando no viene override.
         Setear GROUPS/GRUPOS explicitos al invocar kitchen.sh fuerza un grupo puntual. -->
    <parameter><name>GROUPS</name><default_value></default_value></parameter>
    <parameter><name>GRUPOS</name><default_value></default_value></parameter>
    <parameter><name>CANTREG</name><default_value>20000</default_value></parameter>

    <parameter><name>MYSQL_HOST</name><default_value>${MYSQL_HOST}</default_value></parameter>
    <parameter><name>MYSQL_DB</name><default_value>${MYSQL_DB}</default_value></parameter>
    <parameter><name>MYSQL_USER</name><default_value>${MYSQL_USER}</default_value></parameter>
    <parameter><name>MYSQL_PASSWORD</name><default_value>${MYSQL_PASSWORD}</default_value></parameter>
    <parameter><name>MYSQL_PORT</name><default_value>${MYSQL_PORT}</default_value></parameter>

    <parameter><name>PREDICT_PERIODS</name><default_value>14</default_value></parameter>
    <parameter><name>PREDICT_MODEL_SET</name><default_value>classic</default_value></parameter>
    <parameter><name>PREDICT_VERSION</name><default_value>1</default_value></parameter>
    <parameter><name>PREDICT_RESAMPLE_RULE</name><default_value>MS</default_value></parameter>

    <parameter><name>FORCE_START</name><default_value></default_value></parameter>
    <parameter><name>FORCE_END</name><default_value></default_value></parameter>

    <parameter><name>LAST_TABLE</name><default_value>ventas_historicas_stage</default_value></parameter>
  </parameters>

  <connection>
    <name>MYSQL_EVALUTIA</name>
    <server>${MYSQL_HOST}</server>
    <type>MYSQL</type>
    <access>Native</access>
    <database>${MYSQL_DB}</database>
    <port>${MYSQL_PORT}</port>
    <username>${MYSQL_USER}</username>
    <password>${MYSQL_PASSWORD}</password>
  </connection>

  <entries>
    <entry>
      <name>START</name>
      <type>SPECIAL</type>
      <start>Y</start>
      <xloc>64</xloc><yloc>64</yloc><draw>Y</draw>
    </entry>

    <entry>
      <name>TRUNCATE VENTAS_STAGE</name>
      <type>SQL</type>
      <connection>MYSQL_EVALUTIA</connection>
      <sql><![CDATA[
DELETE FROM ventas_historicas_stage;
      ]]></sql>
      <xloc>240</xloc><yloc>64</yloc><draw>Y</draw>
    </entry>

    <entry>
      <name>RUN EXTRACT ARTICULOS</name>
      <type>SHELL</type>
      <filename>/bin/sh</filename>
      <work_directory>${Internal.Entry.Current.Directory}</work_directory>
      <arguments><argument>-c</argument></arguments>
      <insertScript>Y</insertScript>
      <script><![CDATA[
/bin/bash /app/services/etl/run_extract_articulos.sh
      ]]></script>
      <wait>Y</wait>
      <xloc>480</xloc><yloc>64</yloc><draw>Y</draw>
    </entry>

    <entry>
      <name>TRUNCATE STOCK_DIARIO_STAGE (opcional)</name>
      <type>SQL</type>
      <connection>MYSQL_EVALUTIA</connection>
      <sql><![CDATA[
-- si tenés tabla stage para stock, borrar; si no, se omite
DELETE FROM stock_diario_stage;
      ]]></sql>
      <xloc>720</xloc><yloc>64</yloc><draw>Y</draw>
    </entry>

    <entry>
      <name>RUN EXTRACT STOCKXML</name>
      <type>SHELL</type>
      <filename>/bin/sh</filename>
      <work_directory>${Internal.Entry.Current.Directory}</work_directory>
      <arguments><argument>-c</argument></arguments>
      <insertScript>Y</insertScript>
      <script><![CDATA[
/bin/bash /app/services/etl/run_extract_stockxml.sh
      ]]></script>
      <wait>Y</wait>
      <xloc>960</xloc><yloc>64</yloc><draw>Y</draw>
    </entry>

    <entry>
      <name>MERGE STAGING -> STOCK_DIARIO</name>
      <type>SQL</type>
      <connection>MYSQL_EVALUTIA</connection>
      <sql><![CDATA[
-- Inserta/actualiza desde stock_diario (si el extract puso directamente en stock_diario, este paso puede ser noop)
-- Si optás por tener stock_diario_stage, adaptá FROM accordingly.
-- Aquí asumimos que run_extract_stockxml.py ya escribió en stock_diario.
SELECT 1;
      ]]></sql>
      <xloc>1200</xloc><yloc>64</yloc><draw>Y</draw>
    </entry>

    <entry>
      <name>RUN EXTRACT VENTAS</name>
      <type>SHELL</type>
      <filename>/bin/sh</filename>
      <work_directory>${Internal.Entry.Current.Directory}</work_directory>
      <arguments><argument>-c</argument></arguments>
      <insertScript>Y</insertScript>
      <script><![CDATA[
/bin/bash /app/services/etl/run_extract_sales_chunk.sh
      ]]></script>
      <wait>Y</wait>
      <xloc>1440</xloc><yloc>64</yloc><draw>Y</draw>
    </entry>

    <entry>
      <name>MERGE STAGING -> VENTAS (con snapshot)</name>
      <type>SQL</type>
      <connection>MYSQL_EVALUTIA</connection>
      <sql><![CDATA[
-- MERGE corregido: suma cantidad por SKU+fecha a traves de todos los depositos
-- (ventas_historicas no tiene deposito_id en su clave unica; sin el SUM/GROUP BY,
-- cada deposito pisaba el valor del anterior en vez de acumularse - issue #39 ampliado).
INSERT INTO ventas_historicas
  (fecha, sku, cantidad, ts_carga, fuente)
SELECT
  DATE(s.fecha) AS fecha,
  TRIM(s.sku) AS sku,
  SUM(CAST(s.cantidad AS DECIMAL(12,3))) AS cantidad,
  NOW(6) AS ts_carga,
  COALESCE(MIN(s.fuente),'ws_consstockventa') AS fuente
FROM ventas_historicas_stage s
WHERE s.sku IS NOT NULL
GROUP BY DATE(s.fecha), TRIM(s.sku)
ON DUPLICATE KEY UPDATE
  cantidad = VALUES(cantidad),
  ts_carga = VALUES(ts_carga),
  fuente   = VALUES(fuente);
      ]]></sql>
      <xloc>1680</xloc><yloc>64</yloc><draw>Y</draw>
    </entry>

    <entry>
      <name>CALC_UPSERT_VENTAS_MENSUALES</name>
      <type>SQL</type>
      <connection>MYSQL_EVALUTIA</connection>
      <sql><![CDATA[
INSERT INTO ventas_mensuales
  (sku, year, month, ventas_cantidad, dias_con_stock, fuente, ts_carga)
SELECT
  u.sku, u.year, u.month,
  COALESCE(v.ventas_cantidad, 0) as ventas_cantidad,
  COALESCE(d.dias_con_stock, 0) as dias_con_stock,
  'calculado',
  NOW(6)
FROM (
  SELECT sku, YEAR(fecha) AS year, MONTH(fecha) AS month
  FROM ventas_historicas
  UNION
  SELECT sku, YEAR(fecha) AS year, MONTH(fecha) AS month
  FROM stock_diario
) u
LEFT JOIN (
  SELECT sku, YEAR(fecha) AS year, MONTH(fecha) AS month, SUM(cantidad) AS ventas_cantidad
  FROM ventas_historicas
  GROUP BY sku, YEAR(fecha), MONTH(fecha)
) v ON v.sku = u.sku AND v.year = u.year AND v.month = u.month
LEFT JOIN (
  SELECT sd.sku, YEAR(sd.fecha) AS year, MONTH(sd.fecha) AS month,
         COUNT(DISTINCT sd.fecha) AS dias_con_stock
  FROM stock_diario sd
  JOIN articulos a ON a.sku = sd.sku
  WHERE sd.cantidad > COALESCE(a.stock_minimo,0)
  GROUP BY sd.sku, YEAR(sd.fecha), MONTH(sd.fecha)
) d ON d.sku = u.sku AND d.year = u.year AND d.month = u.month
ON DUPLICATE KEY UPDATE
  ventas_cantidad = VALUES(ventas_cantidad),
  dias_con_stock  = VALUES(dias_con_stock),
  actualizado_en = NOW(6);
      ]]></sql>
      <xloc>1920</xloc><yloc>64</yloc><draw>Y</draw>
    </entry>

    <entry>
      <name>RUN PREDICT.PY</name>
      <type>SHELL</type>
      <filename>/bin/sh</filename>
      <work_directory>${Internal.Entry.Current.Directory}</work_directory>
      <arguments><argument>-c</argument></arguments>
      <insertScript>Y</insertScript>
      <script><![CDATA[
/app/services/etl/run_predict.sh
      ]]></script>
      <wait>Y</wait>
      <xloc>2160</xloc><yloc>64</yloc><draw>Y</draw>
    </entry>

    <entry>
      <name>RUN CALC_PLANILLA</name>
      <type>SHELL</type>
      <filename>/bin/sh</filename>
      <work_directory>${Internal.Entry.Current.Directory}</work_directory>
      <arguments><argument>-c</argument></arguments>
      <insertScript>Y</insertScript>
      <script><![CDATA[
/app/services/etl/run_calc_planilla.sh
      ]]></script>
      <wait>Y</wait>
      <xloc>2280</xloc><yloc>64</yloc><draw>Y</draw>
    </entry>

    <entry>
      <name>RUN CALC_SUGERENCIAS</name>
      <type>SHELL</type>
      <filename>/bin/sh</filename>
      <work_directory>${Internal.Entry.Current.Directory}</work_directory>
      <arguments><argument>-c</argument></arguments>
      <insertScript>Y</insertScript>
      <script><![CDATA[
/app/services/etl/run_calc_sugerencias.sh
      ]]></script>
      <wait>Y</wait>
      <xloc>2340</xloc><yloc>64</yloc><draw>Y</draw>
    </entry>

    <entry>
      <name>TRUNCATE VENTAS_STAGE END</name>
      <type>SQL</type>
      <connection>MYSQL_EVALUTIA</connection>
      <sql><![CDATA[
DELETE FROM ventas_historicas_stage;
      ]]></sql>
      <xloc>2400</xloc><yloc>64</yloc><draw>Y</draw>
    </entry>

    <entry>
      <name>SUCCESS</name>
      <type>SPECIAL</type>
      <success>Y</success>
      <xloc>2640</xloc><yloc>64</yloc><draw>Y</draw>
    </entry>
  </entries>

  <hops>
    <hop><from>START</from><to>TRUNCATE VENTAS_STAGE</to><enabled>Y</enabled><unconditional>Y</unconditional></hop>
    <hop><from>TRUNCATE VENTAS_STAGE</from><to>RUN EXTRACT ARTICULOS</to><enabled>Y</enabled><unconditional>Y</unconditional></hop>
    <hop><from>RUN EXTRACT ARTICULOS</from><to>TRUNCATE STOCK_DIARIO_STAGE (opcional)</to><enabled>Y</enabled><unconditional>Y</unconditional></hop>
    <hop><from>TRUNCATE STOCK_DIARIO_STAGE (opcional)</from><to>RUN EXTRACT STOCKXML</to><enabled>Y</enabled><unconditional>Y</unconditional></hop>
    <hop><from>RUN EXTRACT STOCKXML</from><to>MERGE STAGING -> STOCK_DIARIO</to><enabled>Y</enabled><unconditional>Y</unconditional></hop>
    <hop><from>MERGE STAGING -> STOCK_DIARIO</from><to>RUN EXTRACT VENTAS</to><enabled>Y</enabled><unconditional>Y</unconditional></hop>
    <hop><from>RUN EXTRACT VENTAS</from><to>MERGE STAGING -> VENTAS (con snapshot)</to><enabled>Y</enabled><unconditional>Y</unconditional></hop>
    <hop><from>MERGE STAGING -> VENTAS (con snapshot)</from><to>CALC_UPSERT_VENTAS_MENSUALES</to><enabled>Y</enabled><unconditional>Y</unconditional></hop>
    <hop><from>CALC_UPSERT_VENTAS_MENSUALES</from><to>RUN PREDICT.PY</to><enabled>Y</enabled><unconditional>Y</unconditional></hop>
    <hop><from>RUN PREDICT.PY</from><to>RUN CALC_PLANILLA</to><enabled>Y</enabled><unconditional>Y</unconditional></hop>
    <hop><from>RUN CALC_PLANILLA</from><to>RUN CALC_SUGERENCIAS</to><enabled>Y</enabled><unconditional>Y</unconditional></hop>
    <hop><from>RUN CALC_SUGERENCIAS</from><to>TRUNCATE VENTAS_STAGE END</to><enabled>Y</enabled><unconditional>Y</unconditional></hop>
    <hop><from>TRUNCATE VENTAS_STAGE END</from><to>SUCCESS</to><enabled>Y</enabled><unconditional>Y</unconditional></hop>
  </hops>

  <job_parameters>
    <pass_all_parameters>Y</pass_all_parameters>
  </job_parameters>
</job>