<?xml version="1.0" encoding="UTF-8"?>
<transformation>
  <name>GEN CHUNKS</name>
  <description>Genera [CHUNK_START, CHUNK_END] con CTE recursiva en MySQL</description>

  <info>
    <name>GEN CHUNKS</name>
    <trans_type>Normal</trans_type>
    <size_rowset>10000</size_rowset>
  </info>

  <connection>
    <name>MYSQL_EVALUTIA</name>
    <server>${MYSQL_HOST}</server>
    <type>MYSQL</type>
    <access>Native</access>
    <database>${MYSQL_DB}</database>
    <port>3306</port>
    <username>${MYSQL_USER}</username>
    <password>${MYSQL_PASSWORD}</password>
    <attributes>
      <attribute><code>EXTRA_OPTION_MYSQL.useSSL</code><attribute>false</attribute></attribute>
      <attribute><code>EXTRA_OPTION_MYSQL.allowPublicKeyRetrieval</code><attribute>true</attribute></attribute>
      <attribute><code>EXTRA_OPTION_MYSQL.serverTimezone</code><attribute>UTC</attribute></attribute>
      <attribute><code>EXTRA_OPTION_MYSQL.tinyInt1isBit</code><attribute>false</attribute></attribute>
      <attribute><code>EXTRA_OPTION_MYSQL.useCursorFetch</code><attribute>true</attribute></attribute>
    </attributes>
  </connection>

<step>
  <name>Table input</name>
  <type>TableInput</type>
  <description/>
  <distribute>Y</distribute>
  <copies>1</copies>
  <partitioning>
    <method>none</method>
    <schema_name/>
  </partitioning>

  <connection>MYSQL_EVALUTIA</connection>

  <sql><![CDATA[
WITH RECURSIVE d AS (
  SELECT DATE_ADD(CAST('${LAST_LOADED_DATE}' AS DATE), INTERVAL 1 DAY) AS d0
  UNION ALL
  SELECT DATE_ADD(d0, INTERVAL ${CHUNK_DAYS} DAY) FROM d
  WHERE d0 <= CURRENT_DATE()
),
ranges AS (
  SELECT
    d0 AS CHUNK_START,
    LEAST(DATE_ADD(d0, INTERVAL ${CHUNK_DAYS}-1 DAY), CURRENT_DATE()) AS CHUNK_END
  FROM d
)
SELECT DATE_FORMAT(CHUNK_START,'%Y-%m-%d') AS CHUNK_START,
       DATE_FORMAT(CHUNK_END,  '%Y-%m-%d') AS CHUNK_END
FROM ranges
ORDER BY CHUNK_START;
  ]]></sql>

  <replace_variables>Y</replace_variables>

  <rowlimit>0</rowlimit>
  <lookup>Y</lookup>
  <execute_each_row>N</execute_each_row>
  <variables_active>N</variables_active>
  <lazy_conversion_active>N</lazy_conversion_active>
</step>


  <!-- Paso dummy solo para visibilidad si querés loguear -->
  <step>
    <name>Dummy</name>
    <type>Dummy</type>
    <draw>Y</draw><copies>1</copies>
    <GUI><xloc>480</xloc><yloc>112</yloc><draw>Y</draw></GUI>
  </step>

  <hop><from>Table input</from><to>Dummy</to><enabled>Y</enabled></hop>

  <order/><step_error_handling/>
</transformation>
