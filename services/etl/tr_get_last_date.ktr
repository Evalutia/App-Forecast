<?xml version="1.0" encoding="UTF-8"?>
<transformation>
  <name>GET LAST DATE</name>
  <description>Lee MAX(fecha) de ventas_historicas y setea LAST_LOADED_DATE</description>

  <info>
    <name>GET LAST DATE</name>
    <trans_type>Normal</trans_type>
    <size_rowset>10000</size_rowset>
  </info>

  <connection>
    <name>MYSQL_EVALUTIA</name>
    <server>${MYSQL_HOST}</server>
    <type>MYSQL</type>
    <access>Native</access>
    <database>${MYSQL_DB}</database>
    <port>3306</port>
    <username>${MYSQL_USER}</username>
    <password>${MYSQL_PASSWORD}</password>
    <attributes>
      <attribute><code>EXTRA_OPTION_MYSQL.useSSL</code><attribute>false</attribute></attribute>
      <attribute><code>EXTRA_OPTION_MYSQL.allowPublicKeyRetrieval</code><attribute>true</attribute></attribute>
      <attribute><code>EXTRA_OPTION_MYSQL.serverTimezone</code><attribute>UTC</attribute></attribute>
      <attribute><code>EXTRA_OPTION_MYSQL.tinyInt1isBit</code><attribute>false</attribute></attribute>
      <attribute><code>EXTRA_OPTION_MYSQL.useCursorFetch</code><attribute>true</attribute></attribute>
    </attributes>
  </connection>

  <step>
    <name>Table input</name>
    <type>TableInput</type>
    <connection>MYSQL_EVALUTIA</connection>
    <sql><![CDATA[
SELECT COALESCE(DATE_FORMAT(MAX(fecha),'%Y-%m-%d'), '${WS_START_DATE}') AS last_date
FROM ventas_historicas;
    ]]></sql>
    <replace_variables>Y</replace_variables>
    <rowlimit>1</rowlimit>
    <draw>Y</draw><copies>1</copies>
    <GUI><xloc>128</xloc><yloc>112</yloc><draw>Y</draw></GUI>
  </step>

  <step>
    <name>Set Variables</name>
    <type>SetVariable</type>
    <replace_vars>Y</replace_vars>
    <use_formatting>Y</use_formatting>
    <fields>
      <field>
        <variable_name>LAST_LOADED_DATE</variable_name>
        <variable_value>last_date</variable_value>
        <variable_type>JVM</variable_type>
        <default_value>${WS_START_DATE}</default_value>
      </field>
    </fields>
    <draw>Y</draw><copies>1</copies>
    <GUI><xloc>416</xloc><yloc>112</yloc><draw>Y</draw></GUI>
  </step>

  <step>
    <name>Write to log</name>
    <type>WriteToLog</type>
    <loglevel>Basic</loglevel>
    <displayHeader>Y</displayHeader>
    <limitRows>N</limitRows>
    <logmessage>LAST_LOADED_DATE=${LAST_LOADED_DATE}</logmessage>
    <draw>Y</draw><copies>1</copies>
    <GUI><xloc>640</xloc><yloc>112</yloc><draw>Y</draw></GUI>
  </step>

  <hop><from>Table input</from><to>Set Variables</to><enabled>Y</enabled></hop>
  <hop><from>Set Variables</from><to>Write to log</to><enabled>Y</enabled></hop>

  <order/><step_error_handling/>
</transformation>
