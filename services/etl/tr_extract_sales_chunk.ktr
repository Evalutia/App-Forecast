<?xml version="1.0" encoding="UTF-8"?>
<transformation>
  <name>LOAD SALES CHUNK</name>
  <description>Usa ${CHUNK_START}/${CHUNK_END}, llama SOAP, normaliza y escribe staging</description>

  <info>
    <name>LOAD SALES CHUNK</name>
    <trans_type>Normal</trans_type>
    <size_rowset>10000</size_rowset>
  </info>

  <!-- Conexión MySQL -->
  <connection>
    <name>MYSQL_EVALUTIA</name>
    <server>mysql</server>
    <type>MYSQL</type>
    <access>Native</access>
    <database>evalutia</database>
    <port>3306</port>
    <username>evalutia</username>
    <password>evalutia</password>
    <attributes>
      <attribute><code>EXTRA_OPTION_MYSQL.useSSL</code><attribute>false</attribute></attribute>
      <attribute><code>EXTRA_OPTION_MYSQL.allowPublicKeyRetrieval</code><attribute>true</attribute></attribute>
      <attribute><code>EXTRA_OPTION_MYSQL.serverTimezone</code><attribute>UTC</attribute></attribute>
      <attribute><code>EXTRA_OPTION_MYSQL.tinyInt1isBit</code><attribute>false</attribute></attribute>
      <attribute><code>EXTRA_OPTION_MYSQL.useCursorFetch</code><attribute>true</attribute></attribute>
    </attributes>
  </connection>

  <order/>
  <step_error_handling/>

  <!-- 1) Obtener variables -->
  <step>
    <name>Get Vars</name>
    <type>GetVariable</type>
    <fields>
      <field><name>WS_URL</name><variable>${WS_URL}</variable><type>String</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision></field>
      <field><name>WS_SOAP_ACTION</name><variable>${WS_SOAP_ACTION}</variable><type>String</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision></field>
      <field><name>CHUNK_START</name><variable>${CHUNK_START}</variable><type>String</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision></field>
      <field><name>CHUNK_END</name><variable>${CHUNK_END}</variable><type>String</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision></field>
      <field><name>ID_GRUPO</name><variable>${ID_GRUPO}</variable><type>String</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision></field>
    </fields>
    <GUI><xloc>96</xloc><yloc>96</yloc><draw>Y</draw></GUI>
    <copies>1</copies>
  </step>

  <!-- 2) Armar SOAP Envelope -->
  <step>
    <name>Build SOAP Envelope</name>
    <type>ModifiedJavaScriptValue</type>
    <compatible>Y</compatible>
    <jsScripts>
      <jsScript>
        <script>
var soapBody =
'&lt;?xml version="1.0" encoding="utf-8"?&gt;' +
'&lt;soap:Envelope xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" ' +
'                xmlns:xsd="http://www.w3.org/2001/XMLSchema" ' +
'                xmlns:soap="http://schemas.xmlsoap.org/soap/envelope/"&gt;' +
'  &lt;soap:Body&gt;' +
'    &lt;VentasPorPeriodoJSON xmlns="http://tempuri.org/"&gt;' +
'      &lt;FechaDesde&gt;' + CHUNK_START + '&lt;/FechaDesde&gt;' +
'      &lt;FechaHasta&gt;' + CHUNK_END   + '&lt;/FechaHasta&gt;' +
'      &lt;IdGrupo&gt;'    + (ID_GRUPO || "201") + '&lt;/IdGrupo&gt;' +
'    &lt;/VentasPorPeriodoJSON&gt;' +
'  &lt;/soap:Body&gt;' +
'&lt;/soap:Envelope&gt;';

SOAP_URL   = (WS_URL || '').replace(/\/+$/,'') + '/VsWebProduccion/SwNadWeb.asmx';
SOAP_BODY  = soapBody;
SOAP_ACTION= WS_SOAP_ACTION || 'http://tempuri.org/VentasPorPeriodoJSON';
        </script>
        <position>0</position>
      </jsScript>
    </jsScripts>
    <fields>
      <field><name>SOAP_URL</name><rename>SOAP_URL</rename><type>String</type><length>-1</length><precision>-1</precision></field>
      <field><name>SOAP_BODY</name><rename>SOAP_BODY</rename><type>String</type><length>-1</length><precision>-1</precision></field>
      <field><name>SOAP_ACTION</name><rename>SOAP_ACTION</rename><type>String</type><length>-1</length><precision>-1</precision></field>
    </fields>
    <GUI><xloc>320</xloc><yloc>96</yloc><draw>Y</draw></GUI>
    <copies>1</copies>
  </step>

  <!-- 3) Llamada SOAP vía REST -->
  <step>
    <name>REST SOAP Call</name>
    <type>Rest</type>
    <method>POST</method>
    <url_in_field>Y</url_in_field>
    <url_field>SOAP_URL</url_field>
    <matrix_parameters_active>N</matrix_parameters_active>
    <application_type>application/xml</application_type>
    <body_field>SOAP_BODY</body_field>
    <http_status_field>http_status</http_status_field>
    <result_field_name>response_body</result_field_name>
    <response_time_field_name>response_time</response_time_field_name>
    <result_code_field_name>result_code</result_code_field_name>
    <response_header_field_name>response_headers</response_header_field_name>
    <headers>
      <header><name>Content-Type</name><value>text/xml; charset=utf-8</value></header>
      <header><name>SOAPAction</name><value>${WS_SOAP_ACTION}</value></header>
    </headers>
    <GUI><xloc>560</xloc><yloc>96</yloc><draw>Y</draw></GUI>
    <copies>1</copies>
  </step>

  <!-- 4) Extraer JSON del SOAP -->
  <step>
    <name>Extract JSON from SOAP</name>
    <type>ModifiedJavaScriptValue</type>
    <compatible>Y</compatible>
    <jsScripts>
      <jsScript>
        <script>
var json_text = "[]";
try {
  var s = String(response_body || "");
  var re = /&lt;[^&gt;:]*:?[^&gt;]*Result[^&gt;]*&gt;([\\s\\S]*?)&lt;\\/[^&lt;:]*:?[^&lt;]*Result&gt;/i;
  var m = s.match(re);
  if (m &amp;&amp; m[1]) {
    var t = m[1]
      .replace(/&amp;quot;/g, '"')
      .replace(/&amp;lt;/g, '&lt;')
      .replace(/&amp;gt;/g, '&gt;')
      .replace(/&amp;amp;/g, '&amp;')
      .trim();
    json_text = t;
  }
} catch(e) {
  json_text = "[]";
}
JSON_TEXT = json_text;
        </script>
        <position>0</position>
      </jsScript>
    </jsScripts>
    <fields>
      <field><name>JSON_TEXT</name><rename>JSON_TEXT</rename><type>String</type><length>-1</length><precision>-1</precision></field>
    </fields>
    <GUI><xloc>800</xloc><yloc>96</yloc><draw>Y</draw></GUI>
    <copies>1</copies>
  </step>

  <!-- 5) Parsear JSON -->
  <step>
    <name>JSON Input</name>
    <type>JsonInput</type>
    <readsource>field</readsource>
    <source_field>JSON_TEXT</source_field>
    <IsAFile>N</IsAFile>
    <IsInFields>Y</IsInFields>
    <IsUseJsonPath>Y</IsUseJsonPath>
    <row_path>$[*]</row_path>
    <fields>
      <field><name>sku</name><type>String</type><path>$.Articulo</path></field>
      <field><name>fecha_str</name><type>String</type><path>$.Fecha</path></field>
      <field><name>cantidad</name><type>Integer</type><path>$.Venta</path></field>
      <field><name>stock</name><type>Integer</type><path>$.Stock</path></field>
    </fields>
    <GUI><xloc>1040</xloc><yloc>96</yloc><draw>Y</draw></GUI>
    <copies>1</copies>
  </step>

  <!-- 6) String to Date -->
  <step>
    <name>String to Date</name>
    <type>StringToDate</type>
    <fields>
      <field>
        <in_stream_name>fecha_str</in_stream_name>
        <out_stream_name>fecha</out_stream_name>
        <date_format>yyyy-MM-dd</date_format>
        <lenient>Y</lenient>
        <date_locale>es_ES</date_locale>
        <date_timezone/>
        <field_length>-1</field_length>
        <field_precision>-1</field_precision>
        <grouping_symbol/>
        <decimal_symbol>.</decimal_symbol>
        <currency_symbol/>
      </field>
    </fields>
    <GUI><xloc>1280</xloc><yloc>96</yloc><draw>Y</draw></GUI>
    <copies>1</copies>
  </step>

  <!-- 7) Agregar fuente -->
  <step>
    <name>Add Fuente</name>
    <type>AddConstants</type>
    <fields>
      <field>
        <name>fuente</name>
        <type>String</type>
        <format/>
        <currency/>
        <decimal/>
        <group/>
        <length>-1</length>
        <precision>-1</precision>
        <set_empty_string>N</set_empty_string>
        <value>ws_soap</value>
      </field>
    </fields>
    <GUI><xloc>1520</xloc><yloc>96</yloc><draw>Y</draw></GUI>
    <copies>1</copies>
  </step>

  <!-- 8) Insertar en STAGE -->
  <step>
    <name>Insert STAGE</name>
    <type>TableOutput</type>
    <connection>MYSQL_EVALUTIA</connection>
    <table>ventas_historicas_stage</table>
    <commit>1000</commit>
    <use_batch>Y</use_batch>
    <truncate_table>N</truncate_table>
    <specify_fields>Y</specify_fields>
    <fields>
      <field><stream_name>fecha</stream_name><column_name>fecha</column_name></field>
      <field><stream_name>sku</stream_name><column_name>sku</column_name></field>
      <field><stream_name>cantidad</stream_name><column_name>cantidad</column_name></field>
      <field><stream_name>stock</stream_name><column_name>stock</column_name></field>
      <field><stream_name>fuente</stream_name><column_name>fuente</column_name></field>
    </fields>
    <GUI><xloc>1760</xloc><yloc>96</yloc><draw>Y</draw></GUI>
    <copies>1</copies>
  </step>

  <!-- Hops -->
  <hop><from>Get Vars</from><to>Build SOAP Envelope</to><enabled>Y</enabled></hop>
  <hop><from>Build SOAP Envelope</from><to>REST SOAP Call</to><enabled>Y</enabled></hop>
  <hop><from>REST SOAP Call</from><to>Extract JSON from SOAP</to><enabled>Y</enabled></hop>
  <hop><from>Extract JSON from SOAP</from><to>JSON Input</to><enabled>Y</enabled></hop>
  <hop><from>JSON Input</from><to>String to Date</to><enabled>Y</enabled></hop>
  <hop><from>String to Date</from><to>Add Fuente</to><enabled>Y</enabled></hop>
  <hop><from>Add Fuente</from><to>Insert STAGE</to><enabled>Y</enabled></hop>

  <notepads/>
</transformation>
